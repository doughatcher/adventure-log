# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
.uv/

# Environment — never commit secrets
.env
.env.local
.env.*.local

# Session data — runtime state, not source code
session/transcript.md
session/state.json
session/scene.md
session/story-log.md
session/party.md
session/next-steps.md
session/map.md
session/audio/

# Character data — populated at runtime
data/characters/*.md

# Session archives — track text/state, ignore large audio files
data/sessions/**/*.mp3
data/sessions/**/*.webm
data/sessions/**/filelist.txt

# Hugo build output — regenerated by GitHub Actions
public/

# OS
.DS_Store
Thumbs.db
